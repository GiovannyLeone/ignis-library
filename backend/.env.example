# =============================================================
# BIBLIOTECA IGNIS — Variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env NUNCA deve ser commitado no GitHub.
# =============================================================

# Banco de dados
DB_URL=jdbc:mysql://SEU_HOST:3306/SEU_BANCO?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
DB_USERNAME=SEU_USUARIO
DB_PASSWORD=SUA_SENHA

# JWT — chave secreta mínima de 256 bits (32 caracteres)
JWT_SECRET=UMA_CHAVE_SECRETA_LONGA_DE_PELO_MENOS_256_BITS_AQUI
JWT_EXPIRATION=86400000
